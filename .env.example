# Starter Kit UI — Root Environment Configuration
# This file documents all environment variables used across the project.
# Copy to .env and fill in your values. Do NOT commit .env files.

# ──────────────────────────────────────────────
# Azure Entra ID (Microsoft Identity Platform)
# ──────────────────────────────────────────────
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-backend-api-client-id>
AZURE_AUTHORITY=https://login.microsoftonline.com/<your-tenant-id>

# ──────────────────────────────────────────────
# Azure Blob Storage
# Use connection string for local dev, or account URL for managed identity (deployed).
# ──────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net

# Container names (must match existing pipeline configuration)
BRONZE_CONTAINER=bronze
GOLD_CONTAINER=gold
METADATA_CONTAINER=ui-metadata

# ──────────────────────────────────────────────
# Upload limits
# ──────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=20
ALLOWED_EXTENSIONS=jpg,jpeg,png
