# Starter Kit UI Backend — Environment Configuration
# Copy this file to .env and fill in values.

# Azure Blob Storage (use connection string OR account URL with managed identity)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net

# Container names (must match existing pipeline configuration)
BRONZE_CONTAINER=bronze
GOLD_CONTAINER=gold
METADATA_CONTAINER=ui-metadata

# Azure Entra ID (App Registration for this backend API)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_AUTHORITY=

# CORS — frontend origin
FRONTEND_ORIGIN=http://localhost:3000

# Upload limits
MAX_UPLOAD_SIZE_MB=20
ALLOWED_EXTENSIONS=jpg,jpeg,png
