# Starter Kit UI Frontend — Environment Configuration
# Copy to .env and fill in values from your Entra ID app registrations.
# All variables must use the VITE_ prefix to be exposed to the browser.

# API base URL (empty string when deployed to Azure Static Web Apps — SWA proxies /api/*)
VITE_API_BASE_URL=http://localhost:7071

# Entra ID — Frontend SPA app registration
VITE_AZURE_CLIENT_ID=<your-frontend-spa-client-id>
VITE_AZURE_AUTHORITY=https://login.microsoftonline.com/<your-tenant-id>
VITE_AZURE_REDIRECT_URI=http://localhost:3000

# Backend API scope (from the backend app registration → Expose an API)
VITE_API_SCOPE=api://<your-backend-api-client-id>/access_as_user

# Set to "true" to run in demo mode (no Azure dependencies)
VITE_DEMO_MODE=false
