# Starter Kit UI Frontend — Environment Configuration
# Copy to .env and fill in values from your Entra ID app registration.

REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_AZURE_CLIENT_ID=<your-frontend-app-registration-client-id>
REACT_APP_AZURE_AUTHORITY=https://login.microsoftonline.com/<your-tenant-id>
REACT_APP_AZURE_REDIRECT_URI=http://localhost:3000
REACT_APP_API_SCOPE=api://<your-backend-client-id>/access_as_user
