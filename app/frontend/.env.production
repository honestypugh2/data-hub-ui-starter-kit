# Production environment — Azure Static Web Apps
# SWA proxies /api/* to the linked Azure Functions backend automatically,
# so VITE_API_BASE_URL must be empty (relative paths).
VITE_API_BASE_URL=
VITE_AZURE_CLIENT_ID=<your-frontend-spa-client-id>
VITE_AZURE_AUTHORITY=https://login.microsoftonline.com/<your-tenant-id>
VITE_AZURE_REDIRECT_URI=https://<your-static-web-app-hostname>
VITE_API_SCOPE=api://<your-backend-api-client-id>/access_as_user
