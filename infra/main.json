      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "environmentName": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": [
        "dev",
        "staging",
        "prod"
      ],
      "metadata": {
        "description": "Short environment label (dev, staging, prod)."
      }
    },
    "uniqueSuffix": {
      "type": "string",
      "defaultValue": "[uniqueString(resourceGroup().id)]",
      "metadata": {
        "description": "Unique suffix appended to resource names to avoid global conflicts."
      }
    },
    "tenantId": {
      "type": "string",
      "metadata": {
        "description": "Entra ID tenant ID for JWT validation."
      }
    },
    "apiClientId": {
      "type": "string",
      "metadata": {
        "description": "Entra ID client ID for the backend API app registration."
      }
    },
    "enableNetworkIsolation": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Deploy VNet, private endpoints, and private DNS zones for zero-trust networking."
      }
    },
    "staticWebAppSku": {
      "type": "string",
      "defaultValue": "Free",
      "allowedValues": [
        "Free",
        "Standard"
      ],
      "metadata": {
        "description": "Static Web App SKU. Use \"Free\" for dev/staging, \"Standard\" for prod."
      }
    },
    "pythonVersion": {
      "type": "string",
      "defaultValue": "3.13",
      "metadata": {
        "description": "Function App Python version."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "project": "datahub-ui",
        "phase": "1",
        "environment": "[parameters('environmentName')]"
      },
      "metadata": {
        "description": "Tags applied to all resources."
      }
    }
  },
  "variables": {
    "baseName": "datahub",
    "storageAccountName": "[toLower(format('st{0}{1}', variables('baseName'), parameters('uniqueSuffix')))]",
    "functionAppName": "[format('func-{0}-ui-{1}', variables('baseName'), parameters('uniqueSuffix'))]",
    "appServicePlanName": "[format('asp-{0}-ui-{1}', variables('baseName'), parameters('uniqueSuffix'))]",
    "staticWebAppName": "[format('swa-{0}-{1}', variables('baseName'), parameters('uniqueSuffix'))]",
    "logAnalyticsName": "[format('log-{0}-{1}', variables('baseName'), parameters('uniqueSuffix'))]",
    "appInsightsName": "[format('appi-{0}-{1}', variables('baseName'), parameters('uniqueSuffix'))]",
    "vnetName": "[format('vnet-{0}-{1}', variables('baseName'), parameters('uniqueSuffix'))]"
